# ==========================================
# LUMINA-AI SYSTEM ENVIRONMENT SPECIFICATION
# ==========================================

# 1. Core Platform Settings
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
ENABLE_DEMO_ACCOUNT=

# 2. Google Gemini AI API Keys (12-Key Rotation Pool)
# The primary fallback key
GEMINI_API_KEY=
# Comma-separated rotation pool keys
GEMINI_API_KEY_POOL=

# 3. Job Engine Provider API Credentials (Vite-exposed)
VITE_USAJOBS_API_KEY=
VITE_RAPIDAPI_KEY=
VITE_ADZUNA_APP_ID=
VITE_ADZUNA_APP_KEY=

# 4. Firebase Client SDK Authentication Config (Vite-exposed)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
